# Server Configuration
# Port untuk menjalankan server Express
PORT=4000

# MongoDB Development Database
# Local: mongodb://localhost:27017/financial-management
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/financial-management
MONGO_DEV=mongodb://localhost:27017/financial-management

# MongoDB Production Database (opsional)
# MONGO_PROD=mongodb+srv://username:password@cluster.mongodb.net/financial-management

# Environment Mode
# development atau production
NODE_ENV=development

# JWT Secret untuk Bearer Token
# Ganti dengan value acak yang kuat saat production
JWT_SECRET=change-me-in-production